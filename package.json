{
  "name": "dnb-theme",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build:css": "node scripts/build.ts build",
    "build:css:nolint": "node scripts/build.ts build --no-lint",
    "watch:css": "node scripts/build.ts watch",
    "watch:css:nolint": "node scripts/build.ts watch --no-lint",
    "lint:css": "stylelint \"./src/css/**/*.css\" \"./base.css\" --fix --cache",
    "help:css": "node ./scripts/build.ts --help"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "chokidar": "^4.0.3",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.2"
  }
}